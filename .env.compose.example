# Docker Compose project and host bindings.
COMPOSE_PROJECT_NAME=policygpt
POSTGRES_DB=policygpt
POSTGRES_USER=policygpt
POSTGRES_PASSWORD=change_me
POSTGRES_HOST_PORT=5433
BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=3000

# Stable named volumes. Set POSTGRES_VOLUME_NAME to an existing standalone
# PostgreSQL volume only after stopping the old container that uses it.
POSTGRES_VOLUME_NAME=policygpt_postgres_data
CHROMA_VOLUME_NAME=policygpt_chroma_data
UPLOADS_VOLUME_NAME=policygpt_uploads_data
LOGS_VOLUME_NAME=policygpt_logs_data
EVALUATION_RESULTS_VOLUME_NAME=policygpt_evaluation_results_data

# Backend application identity. The current backend accepts development,
# staging, production, or test; release-like Compose uses production.
APP_NAME=PolicyGPT Enterprise
APP_ENV=production
APP_VERSION=0.3.0
DEBUG=false
API_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Structured query logging and evaluation artifact paths inside the backend.
ENABLE_RAG_QUERY_LOGGING=true
RAG_QUERY_LOG_PATH=/app/logs/rag_queries.jsonl
RAG_LOG_INCLUDE_QUESTION=false
POLICYGPT_EVAL_RESULTS_PATH=/app/eval/results/latest_eval_results.json

# Document ingestion and embedded Chroma configuration.
MAX_PDF_UPLOAD_SIZE_MB=10
TEXT_CHUNK_SIZE_CHARS=1200
TEXT_CHUNK_OVERLAP_CHARS=200
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# Pinned public-model revision used only while constructing the backend image.
EMBEDDING_MODEL_REVISION=1110a243fdf4706b3f48f1d95db1a4f5529b4d41
EMBEDDING_BATCH_SIZE=32
CHROMA_COLLECTION_NAME=policygpt_documents
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_ECHO=false

# Retrieval, evidence, and confidence settings.
SEARCH_TOP_K_DEFAULT=5
MIN_RETRIEVAL_SCORE=0.45
RAG_CANDIDATE_RETRIEVAL_FLOOR=0.30
RAG_DIRECT_SUPPORT_SCORE_FLOOR=0.35
RAG_DIRECT_SUPPORT_COVERAGE_MIN=0.60
RAG_WEAK_CONFIDENCE_THRESHOLD=0.40
RAG_MODERATE_CONFIDENCE_THRESHOLD=0.55
RAG_STRONG_CONFIDENCE_THRESHOLD=0.75
RAG_CONFIDENCE_MAX_EVIDENCE_CHUNKS=3
CITATION_EXCERPT_MAX_CHARS=450
LLM_EVIDENCE_MAX_CHARS=1200
MAX_CITATION_CARDS=5

# Provider keys are optional. With no key, supported retrieval remains
# available through the existing citation-only provider fallback.
ENABLE_LLM_ANSWER=true
LLM_PROVIDER=groq
LLM_MAX_OUTPUT_TOKENS=700
LLM_TEMPERATURE=0.1
LLM_MAX_RETRIES=2
LLM_RETRY_BASE_DELAY_SECONDS=1.0
LLM_RETRY_MAX_DELAY_SECONDS=5.0
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL_NAME=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o-mini

# Frontend-safe identity values. FASTAPI_URL is set internally by Compose and
# is intentionally not configured here or exposed to browser code.
NEXT_PUBLIC_APP_NAME=PolicyGPT Enterprise
NEXT_PUBLIC_APP_VERSION=0.3.0
NEXT_PUBLIC_APP_ENV=Local

# Bounded Docker json-file logs.
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=3
