APP_NAME=PolicyGPT Enterprise
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true

API_PREFIX=/api/v1

LOG_LEVEL=INFO

# Stored questions may contain sensitive policy queries. Disable or redact them
# in sensitive environments.
ENABLE_RAG_QUERY_LOGGING=true
RAG_QUERY_LOG_PATH=logs/rag_queries.jsonl
RAG_LOG_INCLUDE_QUESTION=true

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

CORS_ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000,http://localhost:5173

MAX_PDF_UPLOAD_SIZE_MB=10

TEXT_CHUNK_SIZE_CHARS=1200
TEXT_CHUNK_OVERLAP_CHARS=200

EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32

CHROMA_PERSIST_DIRECTORY=data/chroma
CHROMA_COLLECTION_NAME=policygpt_documents

# PostgreSQL stores document metadata; source PDFs remain in local storage.
DATABASE_URL=postgresql+psycopg://policygpt:change_me@localhost:5432/policygpt
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_ECHO=false
DOCUMENT_STORAGE_DIR=data/uploads

SEARCH_TOP_K_DEFAULT=5

MIN_RETRIEVAL_SCORE=0.45

# Candidate floor controls which retrieved chunks are assessed. It is not the
# final answer threshold. Confidence thresholds classify calibrated evidence
# quality; validate production values with the evaluation benchmark.
RAG_CANDIDATE_RETRIEVAL_FLOOR=0.30
RAG_DIRECT_SUPPORT_SCORE_FLOOR=0.35
RAG_DIRECT_SUPPORT_COVERAGE_MIN=0.60
RAG_WEAK_CONFIDENCE_THRESHOLD=0.40
RAG_MODERATE_CONFIDENCE_THRESHOLD=0.55
RAG_STRONG_CONFIDENCE_THRESHOLD=0.75
RAG_CONFIDENCE_MAX_EVIDENCE_CHUNKS=3

CITATION_EXCERPT_MAX_CHARS=450
LLM_EVIDENCE_MAX_CHARS=1200
MAX_CITATION_CARDS=5

ENABLE_LLM_ANSWER=true
LLM_PROVIDER=groq
LLM_MAX_OUTPUT_TOKENS=700
LLM_TEMPERATURE=0.1
# Retry only temporary provider failures. Total attempts equal retries plus one.
LLM_MAX_RETRIES=2
LLM_RETRY_BASE_DELAY_SECONDS=1.0
LLM_RETRY_MAX_DELAY_SECONDS=5.0

GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL_NAME=llama-3.3-70b-versatile

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_NAME=gpt-4o-mini
